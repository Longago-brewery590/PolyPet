[sub_resource type="GDScript" id="GDScript_rnd"]
resource_name = "RandomizeAll"
script/source = "extends Button

func _pressed() -> void:
	for node in get_tree().current_scene.find_children(\"PolyPetAvatar\"):
		if node.has_method(\"RandomizeSeed\"):
			node.RandomizeSeed()
			node.RandomizeNameSeed()
"

[node name="PolyPetFarm" type="PanelContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = SubResource("farm_theme")
theme_override_styles/panel = SubResource("sb_bg")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 20

[node name="ScrollContainer" type="ScrollContainer" parent="MarginContainer"]
layout_mode = 2
horizontal_scroll_mode = 0

[node name="ContentMargin" type="MarginContainer" parent="MarginContainer/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/margin_right = 20

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer/ScrollContainer/ContentMargin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 0

[node name="Spacer" type="Control" parent="MarginContainer/ScrollContainer/ContentMargin/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="GridContainer" type="GridContainer" parent="MarginContainer/ScrollContainer/ContentMargin/VBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 20
theme_override_constants/v_separation = 20
script = SubResource("GDScript_grid")

[node name="Spacer2" type="Control" parent="MarginContainer/ScrollContainer/ContentMargin/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="SceneToggleButton" parent="." instance=ExtResource("1_stb")]

[node name="RandomizeAllButton" type="CanvasLayer" parent="."]
layer = 100

[node name="Button" type="Button" parent="RandomizeAllButton"]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -66.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = 66.0
grow_horizontal = 0
theme_override_colors/icon_normal_color = Color(0.53, 0.33, 0.21, 1)
theme_override_colors/icon_hover_color = Color(0.53, 0.33, 0.21, 1)
theme_override_colors/icon_pressed_color = Color(0.39, 0.22, 0.12, 1)
theme_override_styles/focus = SubResource("sb_rnd_hover")
theme_override_styles/hover = SubResource("sb_rnd_hover")
theme_override_styles/normal = SubResource("sb_rnd_normal")
theme_override_styles/pressed = SubResource("sb_rnd_pressed")
icon = ExtResource("2_rnd")
expand_icon = true
script = SubResource("GDScript_rnd")
