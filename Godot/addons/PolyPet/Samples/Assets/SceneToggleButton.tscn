[gd_scene load_steps=7 format=3]

[ext_resource type="Texture2D" path="res://addons/PolyPet/Samples/Assets/farm.svg" id="1_farm"]
[ext_resource type="Texture2D" path="res://addons/PolyPet/Samples/Assets/creator.svg" id="2_creator"]

[sub_resource type="GDScript" id="GDScript_toggle"]
resource_name = "SceneToggle"
script/source = "extends Button

@export var creator_scene_path: String = \"res://addons/PolyPet/Samples/PolyPetCreator.tscn\"
@export var farm_scene_path: String = \"res://addons/PolyPet/Samples/PolyPetFarm.tscn\"
@export var farm_icon: Texture2D
@export var creator_icon: Texture2D

func _ready() -> void:
	_update_icon()

func _pressed() -> void:
	var current := get_tree().current_scene.scene_file_path
	if current == creator_scene_path:
		get_tree().change_scene_to_file(farm_scene_path)
	else:
		get_tree().change_scene_to_file(creator_scene_path)

func _update_icon() -> void:
	var current := get_tree().current_scene.scene_file_path
	if current == creator_scene_path:
		icon = farm_icon
	else:
		icon = creator_icon
"

[sub_resource type="StyleBoxFlat" id="sb_toggle_normal"]
content_margin_left = 10.0
content_margin_top = 10.0
content_margin_right = 10.0
content_margin_bottom = 10.0
bg_color = Color(1, 0.77, 0.43, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.84, 0.56, 0.32, 1)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_right = 18
corner_radius_bottom_left = 18

[sub_resource type="StyleBoxFlat" id="sb_toggle_hover"]
content_margin_left = 10.0
content_margin_top = 10.0
content_margin_right = 10.0
content_margin_bottom = 10.0
bg_color = Color(1, 0.82, 0.5, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.84, 0.56, 0.32, 1)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_right = 18
corner_radius_bottom_left = 18

[sub_resource type="StyleBoxFlat" id="sb_toggle_pressed"]
content_margin_left = 10.0
content_margin_top = 10.0
content_margin_right = 10.0
content_margin_bottom = 10.0
bg_color = Color(0.93, 0.68, 0.36, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.84, 0.56, 0.32, 1)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_right = 18
corner_radius_bottom_left = 18

[node name="SceneToggleButton" type="CanvasLayer"]
layer = 100

[node name="Button" type="Button" parent="."]
anchors_preset = 0
offset_left = 10.0
offset_top = 10.0
offset_right = 60.0
offset_bottom = 60.0
theme_override_colors/icon_normal_color = Color(0.53, 0.33, 0.21, 1)
theme_override_colors/icon_hover_color = Color(0.53, 0.33, 0.21, 1)
theme_override_colors/icon_pressed_color = Color(0.39, 0.22, 0.12, 1)
theme_override_styles/focus = SubResource("sb_toggle_hover")
theme_override_styles/hover = SubResource("sb_toggle_hover")
theme_override_styles/normal = SubResource("sb_toggle_normal")
theme_override_styles/pressed = SubResource("sb_toggle_pressed")
icon = ExtResource("1_farm")
expand_icon = true
script = SubResource("GDScript_toggle")
farm_icon = ExtResource("1_farm")
creator_icon = ExtResource("2_creator")
